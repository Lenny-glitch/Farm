rules_version = '2';

// Layer 2: Firebase Anonymous Auth separates users' data by uid. A user can
// only read/write their own users/{uid}/... subtree (plots, beds,
// plantings) — no sharing, no cross-user reads, per the brief's minimal
// auth model.
service cloud.firestore {
  match /databases/{database}/documents {
    match /_meta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
